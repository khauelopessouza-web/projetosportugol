programa {
  funcao inicio() {
    inteiro menor, idade
    escreva("unforme sua idade: ")
    leia(idade)

    se(idade < 18){
      escreva("você é um menor de idade. Fala aí menor!!! ")
    }senao{
      escreva("Você e maior de idade.")
    }

    escreva("\n") // coamndo para quebrar a linha
  }
}
